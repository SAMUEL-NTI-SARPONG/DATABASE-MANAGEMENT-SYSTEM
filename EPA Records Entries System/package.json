{
  "name": "epa-records-entries-system",
  "version": "1.0.0",
  "description": "EPA Records Entries System — Environmental Protection Agency Records Management",
  "main": "electron-main.js",
  "author": "EPA Ghana",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder --win",
    "dist:nsis": "electron-builder --win nsis"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "sql.js": "^1.10.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.epa.records",
    "productName": "EPA Records Entries System",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "artifactName": "EPA Records Entries System ${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EPA Records Entries",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "menuCategory": "EPA",
      "license": null
    },
    "afterPack": "./afterPack.js",
    "files": [
      "**/*",
      "!dist/**",
      "!.git/**",
      "!*.accdb",
      "!*.xlsx",
      "!data/**",
      "!uploads/**"
    ],
    "extraResources": [],
    "asar": false
  }
}
